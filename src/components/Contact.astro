---
import { Image } from 'astro:assets';
import avatarImg from '@/assets/avatar.png';
---

<section id="contact" class="py-24 sm:py-32 relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div class="space-y-8">
        <div class="space-y-4">
          <span class="text-[10px] font-black tracking-[0.3em] uppercase text-slate-400 block">Available for projects</span>
          <h2 class="text-4xl sm:text-5xl lg:text-6xl font-black text-slate-900 tracking-tight leading-none">
            Let's build the <br/>
            <span class="text-violet-600">next big thing.</span>
          </h2>
          <p class="text-slate-500 text-lg font-medium max-w-md leading-relaxed">
            I'm always open to discussing new projects, creative ideas, or opportunities to be part of your vision.
          </p>
        </div>

        <div class="glass rounded-[2rem] p-6 sm:p-8 space-y-6 border border-white/60 shadow-2xl relative group overflow-hidden">
          <div class="absolute inset-0 bg-gradient-to-br from-violet-500/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          
          <div class="relative z-10">
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-full overflow-hidden border-2 border-white shadow-md">
                <Image src={avatarImg} alt="Victxrlarixs" class="w-full h-full object-cover" width={40} height={40} />
              </div>
              <div>
                <p class="text-xs font-black text-slate-900 leading-tight">Victxrlarixs</p>
                <p class="text-[10px] font-bold text-violet-600 uppercase tracking-tighter">Ready to start</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="relative">
        <div class="absolute inset-0 bg-violet-200/20 blur-3xl rounded-full"></div>
        <div class="relative grid grid-cols-2 gap-4">
          <div class="glass p-8 rounded-[2.5rem] flex flex-col items-center justify-center text-center space-y-3 group hover:border-violet-200 transition-all">
            <div class="w-12 h-12 rounded-2xl bg-slate-900 text-white flex items-center justify-center group-hover:scale-110 transition-transform">
              <i class="devicon-github-original text-2xl"></i>
            </div>
            <p class="text-xs font-black uppercase tracking-widest text-slate-400">GitHub</p>
            <a href="https://github.com/Victxrlarixs" target="_blank" class="text-sm font-bold text-slate-900 stretched-link">Follow me</a>
          </div>
          <div class="glass p-8 rounded-[2.5rem] flex flex-col items-center justify-center text-center space-y-3 mt-8 group hover:border-violet-200 transition-all">
            <div class="w-12 h-12 rounded-2xl bg-[#0077B5] text-white flex items-center justify-center group-hover:scale-110 transition-transform">
              <i class="devicon-linkedin-plain text-2xl"></i>
            </div>
            <p class="text-xs font-black uppercase tracking-widest text-slate-400">LinkedIn</p>
            <a href="https://www.linkedin.com/in/victxrlarixs/" target="_blank" class="text-sm font-bold text-slate-900 stretched-link">Connect</a>
          </div>

          <div id="grid-copy-email" data-e1="ing.vlarios" data-e2="gmail.com" class="col-span-2 glass p-6 sm:p-8 rounded-[2.5rem] flex flex-col sm:flex-row items-center justify-center text-center sm:text-left gap-4 group hover:border-violet-200 transition-all cursor-pointer relative">
            <div class="w-12 h-12 rounded-2xl bg-slate-900 text-white flex items-center justify-center group-hover:scale-110 group-hover:bg-violet-600 transition-all shadow-lg shadow-black/10">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <p class="text-xs font-black uppercase tracking-widest text-slate-400">Direct Contact</p>
              <p id="email-display-grid" class="text-sm sm:text-base font-bold text-slate-900 leading-none group-hover:text-violet-600 transition-colors mt-1"></p>
            </div>
            <span class="absolute -top-10 left-1/2 -translate-x-1/2 bg-slate-900 text-white text-[10px] px-3 py-1.5 rounded-lg opacity-0 transition-opacity duration-300 pointer-events-none whitespace-nowrap font-bold" id="grid-copy-tooltip">Copy to clipboard</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script src="../scripts/Contact.ts"></script>
