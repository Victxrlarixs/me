---
// Minimal Footer
const currentYear = new Date().getFullYear();
---

<footer class="py-16 border-t border-black/[0.03] relative overflow-hidden" role="contentinfo">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row items-center justify-between gap-8">
      <div class="space-y-2 text-center md:text-left">
        <p class="text-xs font-black tracking-[0.2em] text-slate-900 uppercase">
          © {currentYear} Victxrlarixs
        </p>
      </div>

      <div class="flex items-center gap-6">
        <a href="https://github.com/Victxrlarixs" target="_blank" class="text-slate-400 hover:text-black transition-colors">
          <i class="devicon-github-original text-xl"></i>
        </a>
        <a href="https://www.linkedin.com/in/victxrlarixs/" target="_blank" class="text-slate-400 hover:text-[#0077B5] transition-colors">
          <i class="devicon-linkedin-plain text-xl"></i>
        </a>
      </div>
    </div>
  </div>
</footer>
