---
import { projects } from '../data/projects';
import { fetchGitHubStars } from '../utils/github';
import { Image } from 'astro:assets';

const projectsWithStars = await Promise.all(projects.map(async (p) => ({
  ...p,
  stars: await fetchGitHubStars(p.codeUrl)
})));

const featuredProjects = projectsWithStars.filter(p => p.featured);
const otherProjects = projectsWithStars.filter(p => !p.featured);
---

<section
  id="projects"
  class="relative py-16 sm:py-20"
  aria-labelledby="projects-heading"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="mb-12 sm:mb-16">
      <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 pb-8 border-b border-black/[0.03]">
        <div class="space-y-4">
          <h1
            id="projects-heading"
            class="text-3xl sm:text-4xl lg:text-5xl font-black leading-tight text-slate-900 tracking-tight"
          >
            My projects
            <span class="text-indigo-600">.</span>
          </h1>
          <p class="text-slate-500 text-base leading-relaxed font-medium mb-4">
            Things I've designed, built, and launched.
          </p>
          
          <div class="flex flex-wrap gap-2 pt-2" id="project-filters">
            <button class="filter-btn active px-4 py-1.5 rounded-full text-xs font-bold transition-all duration-300 bg-slate-900 text-white shadow-md shadow-slate-900/20" data-filter="all">All</button>
            <button class="filter-btn px-4 py-1.5 rounded-full text-xs font-bold transition-all duration-300 bg-white/50 text-slate-500 hover:bg-white hover:text-slate-900 hover:shadow border border-black/5" data-filter="professional">Professional</button>
            <button class="filter-btn px-4 py-1.5 rounded-full text-xs font-bold transition-all duration-300 bg-white/50 text-slate-500 hover:bg-white hover:text-slate-900 hover:shadow border border-black/5" data-filter="creative">Creative Coding</button>
            <button class="filter-btn px-4 py-1.5 rounded-full text-xs font-bold transition-all duration-300 bg-white/50 text-slate-500 hover:bg-white hover:text-slate-900 hover:shadow border border-black/5" data-filter="terminal">Terminal / CLI</button>
          </div>
        </div>
      </div>
    </div>

    <div
      class="grid md:grid-cols-3 gap-5 mb-5"
      aria-label="Featured projects"
    >
      {featuredProjects.map((project, i) => (
        <article
          class={`project-card group glass rounded-[2rem] overflow-hidden transition-all duration-500 ease-[cubic-bezier(0.34,1.56,0.64,1)] hover:shadow-2xl hover:shadow-indigo-500/10 hover:-translate-y-2 ${
            i === 0 ? 'md:col-span-2' : 'md:col-span-1'
          }`}
          aria-labelledby={`project-${project.id}-title`}
          data-categories={[...project.stack, project.category, project.vibe].join(',').toLowerCase()}
        >
          <div class={`relative h-56 bg-gradient-to-br ${project.gradient} overflow-hidden`} aria-hidden="true">
            {project.image ? (
              <div class="absolute inset-0 p-4">
                <div class="relative h-full w-full glass rounded-2xl overflow-hidden border border-white/20 shadow-2xl group-hover:scale-[1.02] transition-transform duration-700">
                  <Image 
                    src={project.image} 
                    alt={`Preview of ${project.title}`}
                    class="w-full h-full object-cover object-top"
                    width={800}
                    height={450}
                  />
                  <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
                </div>
              </div>
            ) : (
              <>
                <div
                  class="absolute inset-0 opacity-40 mix-blend-overlay"
                  style={`background: radial-gradient(circle at 30% 40%, ${project.accentColor}, transparent);`}
                ></div>
                
                <div class="absolute inset-0 flex items-center justify-center p-6">
                  <div class="w-full max-w-xs bg-white/10 rounded-2xl border border-white/5 p-4 space-y-3">
                    <div class="flex items-center justify-between">
                      <div class="flex gap-1.5">
                        <div class="w-2 h-2 rounded-full" style={`background: ${project.accentColor};`}></div>
                        <div class="h-2 bg-white/20 rounded w-20"></div>
                      </div>
                    </div>
                    <div class="space-y-1.5">
                      <div class="h-2 bg-white/10 rounded w-full"></div>
                      <div class="h-2 bg-white/10 rounded w-2/3"></div>
                    </div>
                  </div>
                </div>
              </>
            )}
            <div class="absolute top-4 left-4 flex gap-2">
              <span class="px-3 py-1 rounded-full text-[10px] font-black bg-white/90 text-slate-900 uppercase tracking-widest">
                {project.category}
              </span>
              {project.stars > 0 && (
                <div class="px-2 py-1 rounded-full text-[10px] font-black bg-slate-900 text-white flex items-center gap-1 shadow-lg">
                  <svg class="w-2.5 h-2.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                    <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                  </svg>
                  {project.stars}
                </div>
              )}
            </div>
          </div>

          <div class="p-6 space-y-3">
            <div class="flex items-start justify-between gap-2">
              <h2 id={`project-${project.id}-title`} class="font-bold text-slate-900 text-xl leading-tight group-hover:text-indigo-600 transition-colors">
                {project.title}
              </h2>
              <div class="flex gap-1.5 mt-0.5">
                {project.demoUrl && (
                  <a href={project.demoUrl} class="p-1.5 rounded-lg hover:bg-slate-50 text-slate-400 hover:text-indigo-600 transition-colors" target="_blank">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                  </a>
                )}
                {project.codeUrl && (
                  <a href={project.codeUrl} class="p-1.5 rounded-lg hover:bg-slate-50 text-slate-400 hover:text-indigo-600 transition-colors" target="_blank">
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                  </a>
                )}
              </div>
            </div>
            <p class="text-slate-600 text-sm leading-relaxed">{project.description}</p>
            
            <ul class="flex flex-wrap gap-1.5 pt-2" role="list">
              {project.stack.map((tech) => (
                <li>
                  <span class="px-2 py-0.5 rounded-md text-[11px] font-bold bg-slate-50 border border-slate-100 text-slate-500">
                    {tech}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-20 sm:mt-28">
      <div class="flex items-center gap-3 mb-8">
        <h2 class="text-xl sm:text-2xl font-black text-slate-900 tracking-tight">Open Source & Labs</h2>
        <div class="h-px flex-grow bg-black/5"></div>
      </div>

      <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4" role="list">
        {otherProjects.map((project, i) => (
          <li>
            <article 
              class="project-card group relative glass rounded-3xl p-6 h-full flex flex-col transition-all duration-500 ease-[cubic-bezier(0.34,1.56,0.64,1)] hover:shadow-xl hover:shadow-black/5 hover:-translate-y-2"
              data-categories={[...project.stack, project.category, project.vibe].join(',').toLowerCase()}
            >
              <div class="flex items-start justify-between gap-4 mb-4">
                <h3 class="font-bold text-slate-900 text-lg leading-tight mb-2 group-hover:text-indigo-600 transition-colors flex items-center gap-2">
                  {project.title}
                  {project.stars > 0 && (
                    <span class="flex items-center gap-0.5 px-1.5 py-0.5 rounded-md bg-yellow-400/10 text-yellow-600 text-[10px] font-black">
                      <svg class="w-2.5 h-2.5" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                      </svg>
                      {project.stars}
                    </span>
                  )}
                </h3>
                <div class="flex gap-1.5">
                  {project.demoUrl && (
                    <a href={project.demoUrl} class="p-1.5 rounded-lg hover:bg-slate-50 text-slate-400 hover:text-indigo-600 transition-colors" target="_blank" aria-label={`View demo for ${project.title}`}>
                      <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                    </a>
                  )}
                  {project.codeUrl && (
                    <a href={project.codeUrl} class="p-1.5 rounded-lg hover:bg-slate-50 text-slate-400 hover:text-indigo-600 transition-colors" target="_blank" aria-label={`Source code for ${project.title}`}>
                      <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                    </a>
                  )}
                </div>
              </div>
              <p class="text-slate-600 text-sm leading-relaxed mb-4">{project.description}</p>
              
              <ul class="flex flex-wrap gap-1.5 mt-auto" role="list">
                {project.stack.map((tech) => (
                  <li>
                    <span class="px-2 py-0.5 rounded-md text-[10px] font-bold bg-slate-50 border border-slate-100 text-slate-500">
                      {tech}
                    </span>
                  </li>
                ))}
              </ul>
            </article>
          </li>
        ))}

        <li>
          <a
            href="https://github.com/victxrlarixs"
            target="_blank"
            rel="noopener noreferrer"
            class="group glass rounded-3xl border border-dashed border-black/10 hover:border-indigo-200 hover:bg-white/60 p-6 h-full flex flex-col items-center justify-center gap-3 text-center transition-all duration-300 min-h-[180px]"
            aria-label="View more projects on GitHub"
          >
            <div class="w-12 h-12 rounded-full glass border border-black/5 flex items-center justify-center group-hover:scale-110 group-hover:border-indigo-200 transition-all duration-300">
              <svg class="w-6 h-6 text-slate-400 group-hover:text-indigo-600 transition-colors duration-200" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            </div>
            <div>
              <p class="text-sm font-bold text-slate-700 group-hover:text-indigo-600 transition-colors duration-200">Explore More</p>
              <p class="text-xs text-slate-500 mt-1">View all repositories on GitHub →</p>
            </div>
          </a>
        </li>
      </ul>
    </div>

    <div class="mt-20 border-t border-black/[0.03] pt-12">
      <div class="mb-8">
        <span class="text-[10px] font-black tracking-[0.3em] uppercase text-slate-400 block mb-1">Collaborations</span>
        <h2 class="text-xl font-black text-slate-900 tracking-tight">Client Work</h2>
      </div>
      
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        {[
          { name: 'Romina', url: 'https://romina.verbenadesign.com.mx/', agency: 'Verbena Design' },
          { name: 'Karla & Ruben', url: 'https://karla-ruben.verbenadesign.com.mx/', agency: 'Verbena Design' },
          { name: 'Arking', url: 'https://arking.com.mx/', agency: 'Cero Marketing' }
        ].map((item) => (
          <a 
            href={item.url} 
            target="_blank" 
            rel="noopener noreferrer"
            class="group glass p-4 rounded-2xl border border-black/[0.03] hover:bg-white hover:shadow-lg transition-all duration-300 flex flex-col gap-1"
          >
            <div class="flex items-center justify-between">
              <span class="text-sm font-bold text-slate-900 group-hover:text-indigo-600 transition-colors">{item.name}</span>
              <svg class="w-3 h-3 text-slate-400 group-hover:text-indigo-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            </div>
            <span class="text-[9px] font-black uppercase tracking-widest text-slate-400">{item.agency}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<script src="../scripts/Projects.ts"></script>
